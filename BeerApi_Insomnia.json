    {
      "_id": "req_register_brewer",
      "parentId": "grp_auth",
      "name": "1. Register Brewer",
      "description": "Creates a new user with role=Brewer and a linked Brewery entity.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/register/brewer",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"brewer@leffe.com\",\n  \"password\": \"Brewer@123!\",\n  \"firstName\": \"Jean\",\n  \"lastName\": \"Dupont\",\n  \"breweryName\": \"Micro Brasserie Test\",\n  \"breweryCountry\": \"Belgium\",\n  \"breweryDescription\": \"A small test brewery for the API demo.\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -700,
      "_type": "request"
    },

    {
      "_id": "req_register_wholesaler",
      "parentId": "grp_auth",
      "name": "2. Register Wholesaler",
      "description": "Creates a new user with role=Wholesaler and a linked Wholesaler entity.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/register/wholesaler",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"buyer@distribution.com\",\n  \"password\": \"Buyer@123!\",\n  \"firstName\": \"Marie\",\n  \"lastName\": \"Durand\",\n  \"wholesalerName\": \"Distribution Test SARL\",\n  \"wholesalerAddress\": \"Rue des Brasseurs 1, 1000 Brussels\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -600,
      "_type": "request"
    },

    {
      "_id": "req_login_admin",
      "parentId": "grp_auth",
      "name": "3. Login — Admin  ⭐",
      "description": "Copy the accessToken from the response and paste it into the environment variable admin_token.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"admin@beerapi.com\",\n  \"password\": \"Admin@123!\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -500,
      "_type": "request"
    },

    {
      "_id": "req_login_brewer",
      "parentId": "grp_auth",
      "name": "4. Login — Brewer",
      "description": "Copy the accessToken from the response and paste it into the environment variable brewer_token.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"brewer@leffe.com\",\n  \"password\": \"Brewer@123!\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -400,
      "_type": "request"
    },

    {
      "_id": "req_login_wholesaler",
      "parentId": "grp_auth",
      "name": "5. Login — Wholesaler",
      "description": "Copy the accessToken from the response and paste it into the environment variable wholesaler_token.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"buyer@distribution.com\",\n  \"password\": \"Buyer@123!\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -300,
      "_type": "request"
    },

    {
      "_id": "req_refresh",
      "parentId": "grp_auth",
      "name": "6. Refresh Token",
      "description": "Paste the refreshToken from any Login response into the environment variable refresh_token.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/refresh",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"refreshToken\": \"{{ refresh_token }}\"\n}"
      },
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "metaSortKey": -200,
      "_type": "request"
    },

    {
      "_id": "req_logout",
      "parentId": "grp_auth",
      "name": "7. Logout",
      "description": "Invalidates the current session. Send an empty JSON body.",
      "method": "POST",
      "url": "{{ base_url }}/api/auth/logout",
      "body": {
        "mimeType": "application/json",
        "text": "{}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ admin_token }}" }
      ],
      "metaSortKey": -100,
      "_type": "request"
    },


    {
      "_id": "req_get_breweries",
