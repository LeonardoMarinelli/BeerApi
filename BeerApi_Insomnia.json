      "metaSortKey": -300,
      "_type": "request"
    },

    {
      "_id": "req_quote_10pct",
      "parentId": "grp_quote_ok",
      "name": "Quote — 10% desconto (>10 unidades)",
      "description": "Total: 6+7=13 unidades → 10% de desconto.\nBeerWorld Brussels (id=1): Leffe Blonde(id=1) e Chimay Rouge(id=4).",
      "method": "POST",
      "url": "{{ base_url }}/api/wholesalers/1/quote",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"items\": [\n    { \"beerId\": 1, \"quantity\": 6 },\n    { \"beerId\": 4, \"quantity\": 7 }\n  ]\n}"
