      "metaSortKey": -200,
      "_type": "request"
    },

    {
      "_id": "req_get_wholesaler_stock",
      "parentId": "grp_wholesalers",
      "name": "Get Wholesaler Stock (id=1)",
      "description": "BeerWorld Brussels stock: Leffe Blonde(50), Chimay Rouge(30), Duvel(40), Stella Artois(100). Run 'Create Sale — Duvel' to see the quantity increase.",
      "method": "GET",
      "url": "{{ base_url }}/api/wholesalers/1/beers",
      "body": {},
      "headers": [{ "name": "Authorization", "value": "Bearer {{ admin_token }}" }],
      "metaSortKey": -100,
      "_type": "request"
    },


    {
      "_id": "req_quote_no_discount",
      "parentId": "grp_quote_ok",
      "name": "Quote — Sem desconto (≤10 unidades)",
      "description": "Total: 3+4=7 unidades → sem desconto.\nBeerWorld Brussels (id=1): Leffe Blonde(id=1) e Chimay Rouge(id=4).",
