      ],
      "metaSortKey": -200,
      "_type": "request"
    },

    {
      "_id": "req_quote_20pct",
      "parentId": "grp_quote_ok",
      "name": "Quote — 20% desconto (>20 unidades)",
      "description": "Total: 10+7+6=23 unidades → 20% de desconto.\nBeerWorld Brussels (id=1): Leffe Blonde(id=1), Chimay Rouge(id=4), Duvel(id=7).",
      "method": "POST",
      "url": "{{ base_url }}/api/wholesalers/1/quote",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"items\": [\n    { \"beerId\": 1, \"quantity\": 10 },\n    { \"beerId\": 4, \"quantity\": 7 },\n    { \"beerId\": 7, \"quantity\": 6 }\n  ]\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
