      "url": "{{ base_url }}/api/wholesalers/1/quote",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"items\": [\n    { \"beerId\": 1, \"quantity\": 3 },\n    { \"beerId\": 4, \"quantity\": 4 }\n  ]\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
