      "metaSortKey": -300,
      "_type": "request"
    },

    {
      "_id": "req_get_brewery_by_id",
      "parentId": "grp_breweries",
      "name": "Get Brewery by ID",
      "description": "IDs 1–7 are seeded. 1=Leffe, 2=Chimay, 3=Duvel, 4=Westmalle, 5=Rochefort, 6=Huyghe, 7=AB InBev.",
      "method": "GET",
      "url": "{{ base_url }}/api/breweries/1",
      "body": {},
      "headers": [{ "name": "Authorization", "value": "Bearer {{ admin_token }}" }],
      "metaSortKey": -200,
      "_type": "request"
    },

    {
      "_id": "req_get_brewery_beers",
      "parentId": "grp_breweries",
      "name": "List Beers of a Brewery",
      "description": "Brewery 2 = Chimay. Returns Chimay Rouge, Bleue and Triple.",
      "method": "GET",
      "url": "{{ base_url }}/api/breweries/2/beers",
      "body": {},
      "headers": [{ "name": "Authorization", "value": "Bearer {{ admin_token }}" }],
      "metaSortKey": -100,
      "_type": "request"
    },


    {
      "_id": "req_create_beer",
      "parentId": "grp_beers",
      "name": "Create Beer (Admin → Brewery 1)",
      "description": "Admin can create beers for any brewery. A Brewer can only use their own breweryId from the URL.\n\nBrewery 1 = Abbaye de Leffe. The new beer will get id=17.",
      "method": "POST",
      "url": "{{ base_url }}/api/breweries/1/beers",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Leffe Ruby\",\n  \"description\": \"A fruity, refreshing red beer with hints of red fruits and subtle bitterness.\",\n  \"alcoholContent\": 5.0,\n  \"price\": 2.70\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ admin_token }}" }
      ],
      "metaSortKey": -400,
      "_type": "request"
    },

    {
      "_id": "req_update_beer",
      "parentId": "grp_beers",
      "name": "Update Beer (Admin → Brewery 1, Beer 17)",
      "description": "Update the beer created above. Run 'Create Beer' first to ensure beer 17 exists.",
      "method": "PUT",
      "url": "{{ base_url }}/api/breweries/1/beers/17",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Leffe Ruby (Updated)\",\n  \"description\": \"Updated description after refinement.\",\n  \"alcoholContent\": 5.0,\n  \"price\": 2.90\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ admin_token }}" }
      ],
      "metaSortKey": -300,
      "_type": "request"
    },

    {
      "_id": "req_delete_beer",
      "parentId": "grp_beers",
      "name": "Delete Beer (Admin → Brewery 1, Beer 17)",
      "description": "Deletes beer 17. Returns 204 No Content on success.",
      "method": "DELETE",
      "url": "{{ base_url }}/api/breweries/1/beers/17",
      "body": {},
      "headers": [{ "name": "Authorization", "value": "Bearer {{ admin_token }}" }],
      "metaSortKey": -200,
      "_type": "request"
    },

    {
      "_id": "req_create_beer_brewer",
      "parentId": "grp_beers",
      "name": "Create Beer (Brewer — own brewery)",
      "description": "Uses brewer_token. The breweryId in the URL must match the brewery linked to this brewer's account.\n\nAfter registering the brewer above, their brewery will be id=8 (seeds 1–7 are taken). Update the URL if needed.",
      "method": "POST",
      "url": "{{ base_url }}/api/breweries/8/beers",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Test Ale\",\n  \"description\": \"A light golden ale with citrus notes.\",\n  \"alcoholContent\": 4.5,\n  \"price\": 3.00\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ brewer_token }}" }
      ],
      "metaSortKey": -100,
      "_type": "request"
    },

    {
      "_id": "req_create_beer_forbidden",
      "parentId": "grp_beers",
      "name": "Create Beer — 403 Forbidden (wrong brewery)",
      "description": "Brewer token but wrong breweryId → expects 403 Forbidden. The brewer owns brewery 8 but is trying to add a beer to brewery 1.",
      "method": "POST",
      "url": "{{ base_url }}/api/breweries/1/beers",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"name\": \"Fake Leffe\",\n  \"description\": \"This should be rejected.\",\n  \"alcoholContent\": 5.0,\n  \"price\": 2.50\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ brewer_token }}" }
      ],
      "metaSortKey": -50,
      "_type": "request"
    },


    {
      "_id": "req_create_sale",
      "parentId": "grp_sales",
      "name": "Create Sale (Admin) — Duvel to BeerWorld Brussels",
      "description": "Sells 10 units of Duvel (beerId=7, breweryId=3) to BeerWorld Brussels (wholesalerId=1).\nIncrements the wholesaler's stock by the sold quantity.\n\nNote: Admin can sell any brewery's beer. A Brewer can only sell their own brewery's beers.",
      "method": "POST",
      "url": "{{ base_url }}/api/sales",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"beerId\": 7,\n  \"wholesalerId\": 1,\n  \"quantity\": 10\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ admin_token }}" }
      ],
      "metaSortKey": -300,
      "_type": "request"
    },

    {
      "_id": "req_create_sale_new_beer",
      "parentId": "grp_sales",
      "name": "Create Sale — New beer/wholesaler combo",
      "description": "Sells Westmalle Dubbel (beerId=9) to Belgian Beer Wholesale (wholesalerId=2).\nThis beer is NOT currently in wholesaler 2's stock, so it creates a new stock entry.",
      "method": "POST",
      "url": "{{ base_url }}/api/sales",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"beerId\": 9,\n  \"wholesalerId\": 2,\n  \"quantity\": 30\n}"
      },
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ admin_token }}" }
      ],
      "metaSortKey": -200,
      "_type": "request"
    },


